{
  "name": "@sgaluza/api-to-mcp",
  "version": "0.2.3",
  "description": "Turn any OpenAPI or GraphQL API into an MCP server via stdio bridge.",
  "type": "module",
  "bin": {
    "api-to-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "openapi",
    "graphql",
    "model-context-protocol",
    "bridge",
    "api",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgaluza/api-to-mcp.git"
  },
  "homepage": "https://github.com/sgaluza/api-to-mcp#readme",
  "bugs": {
    "url": "https://github.com/sgaluza/api-to-mcp/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "graphql": "^16.13.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
